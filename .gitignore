# Nothing from there should ever be committed.
data/
app_data/

# ── Frontend build output ─────────────────────────────────────────────
frontend/dist/
frontend/node_modules/

# ── Environment / secrets ─────────────────────────────────────────────
.env
.env.*
*.env
config.json
secrets.*

# ── OS & editor artifacts ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# ── Logs ──────────────────────────────────────────────────────────────
*.log
logs/
